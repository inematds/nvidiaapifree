# Chave gratuita da NVIDIA - obtenha em https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXX

# Opcional: chaves separadas por modelo (evita compartilhar rate limit na arena)
# NVIDIA_API_KEY_LLAMA=nvapi-...
# NVIDIA_API_KEY_LLAMA405=nvapi-...
# NVIDIA_API_KEY_DEEPSEEK=nvapi-...
# NVIDIA_API_KEY_QWEN=nvapi-...
# NVIDIA_API_KEY_GLM=nvapi-...
# NVIDIA_API_KEY_NEMOTRON=nvapi-...
# NVIDIA_API_KEY_MISTRAL=nvapi-...
# NVIDIA_API_KEY_VISION=nvapi-...
